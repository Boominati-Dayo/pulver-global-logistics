# SwiftXpress Inc. - Environment Variables
# Copy this file to .env.local and fill in your actual values

# Site URL (change this to your actual domain)
NEXT_PUBLIC_SITE_URL=https://swiftxpressinc.com

# MongoDB Connection
MONGODB_URI=mongodb+srv://your-username:your-password@cluster.mongodb.net/swiftxpress?retryWrites=true&w=majority

# JWT Secret (change this to a random string)
JWT_SECRET=change-this-to-a-random-secret-string

# Admin Login Credentials
ADMIN_EMAIL=admin@swiftxpressinc.com
ADMIN_PASSWORD=SetYourSecurePasswordHere

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# OpenRouteMap API (for tracking map)
OPENROUTE_API_KEY=your-openroute-api-key

# Google Maps API (optional)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key